   {:kaocha.testable/id   :regression
    :kaocha.testable/type :kaocha.type/clojure.test
    :kaocha/source-paths  ["src"]
    :kaocha/test-paths    ["test-regression"]
    :kaocha/ns-patterns   [".*-test$"]}

   {:kaocha.testable/id   :regression-lean
    :kaocha.testable/type :kaocha.type/clojure.test
    :kaocha/source-paths  ["src"]
    :kaocha/test-paths    ["test-regression-lean"]
